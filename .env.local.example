# ====================
# Prohori Environment Variables
# ====================
# Copy this to .env.local and fill in your actual values

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://placeholder.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder_anon_key
SUPABASE_SERVICE_ROLE_KEY=placeholder_service_role_key

# --- AI Providers ---
GROQ_API_KEY=placeholder_groq_key
GROQ_MODEL=llama3-70b-8192
GROQ_TEMPERATURE=0.5
GROQ_MAX_TOKENS=600

GEMINI_API_KEY=placeholder_gemini_key
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.5
GEMINI_MAX_TOKENS=600

OPENROUTER_API_KEY=placeholder_openrouter_key
OPENROUTER_MODEL=google/gemma-3-12b-it:free
OPENROUTER_TEMPERATURE=0.5
OPENROUTER_MAX_TOKENS=600

HUGGINGFACE_API_KEY=placeholder_hf_key
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_TEMPERATURE=0.5
HUGGINGFACE_MAX_TOKENS=600

# AI Provider Configuration
AI_PROVIDER_PRIORITY=groq,gemini,openrouter,huggingface
AI_FALLBACK_ENABLED=true

# --- Wazuh Encryption ---
# Key used to encrypt Wazuh credentials in the database
# Change this to a secure random string in production
WAZUH_ENCRYPTION_KEY=your-secure-encryption-key-here

# --- Admin Settings ---
# This is the email address of the platform admin (you)
ADMIN_EMAIL=admin@prohori.app

# This is the URL segment for the admin portal (e.g. /hq -> access at yoursite.com/hq)
NEXT_PUBLIC_ADMIN_SEGMENT=hq
NEXT_PUBLIC_ADMIN_EMAIL=admin@prohori.app